[package]
name = "{{ name }}"
edition = "2024"
version = "0.1.0"

[[bin]]
name = "{{ name }}"
path = "src/main.rs"

[build-dependencies]
gluon-build = { path = "../gluon/crates/gluon-build" }

[dependencies]
async-trait = "0.1"
axum = "0.8"
gluon = { path = "../gluon/crates/gluon" }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
sqlx = { version = "0.8", features = ["postgres", "runtime-tokio", "uuid"] }
tokio = { version = "1", features = ["rt-multi-thread", "macros", "signal"] }
tower-sessions = "0.14"
ts-rs = "11"
uuid = { version = "1", features = ["v4", "serde"] }
